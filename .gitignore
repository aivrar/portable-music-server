# ============================================================
# Music Module .gitignore
# ============================================================

# --- Runtime / portable binaries (downloaded by install.bat) ---
python_embedded/
git_portable/
ffmpeg/
espeak-ng/

# --- Model weights & caches ---
models/
pretrained/
venvs/

# --- Generated output ---
output/
temp/

# --- Python caches ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Claude Code ---
.claude/

# --- OS ---
Thumbs.db
Desktop.ini
.DS_Store

# --- Logs ---
*.log
